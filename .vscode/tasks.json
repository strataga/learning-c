{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C Program",
            "type": "shell",
            "command": "mkdir -p ${workspaceFolder}/build && gcc -std=c99 -Wall -g ${workspaceFolder}/src/main.c -o ${workspaceFolder}/build/app",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Current File",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-std=c99",
                "-Wall",
                "-g",
                "${file}", // Compiles the active file
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}" // Outputs to same folder
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}